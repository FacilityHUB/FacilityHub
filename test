-- Auto Serverhop
task.spawn(function()
    while true do
        task.wait(1)
        if not getgenv().AutoServerhop then continue end
        
        local elapsed = tick() - (getgenv().LastHopTime or 0)
        if elapsed < getgenv().HopMins * 60 then continue end
        
        getgenv().LastHopTime = tick()
        
        local TP = game:GetService("TeleportService")
        local success, servers = pcall(function()
            return game:HttpGet("https://games.roblox.com/v1/games/" .. game.PlaceId .. "/servers/Public?sortOrder=Asc&limit=100")
        end)
        if success then
            local data = game:GetService("HttpService"):JSONDecode(servers)
            if data and data.data and #data.data > 0 then
                for _, server in ipairs(data.data) do
                    if server.id ~= game.JobId and server.playing < server.maxPlayers then
                        TP:TeleportToPlaceInstance(game.PlaceId, server.id, LocalPlayer)
                        return
                    end
                end
            end
        end
    end
end)

