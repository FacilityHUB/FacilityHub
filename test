        task.wait(1)
        return
    end

    local bossRoot = boss:FindFirstChild("HumanoidRootPart")
    if bossRoot then moveToTarget(bossRoot) task.wait(0.5) end

    getgenv().CurrentTarget = boss
    local humanoid = boss:FindFirstChild("Humanoid")
    while activeFlagFunc() and humanoid and humanoid.Health > 0 do
        task.wait(0.1)
    end
    getgenv().CurrentTarget = nil
    task.wait(getgenv().TargetTPCD)
end

