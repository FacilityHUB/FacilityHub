-- Auto Kick
local function checkPlayer(targetPlayer)
    if not getgenv().AutoKick then return end
    if targetPlayer == LocalPlayer then return end
    local kickTypes = getgenv().KickTypes or {}
    if kickTypes["Player Join"] then
        LocalPlayer:Kick("\n[Facility Hub]\nReason: A player joined (" .. targetPlayer.Name .. ")")
        return
    end
    if kickTypes["Mod"] then
        local success, rank = pcall(function() return targetPlayer:GetRankInGroup(1002185259) end)
        if success and (rank == 255 or rank == 254 or rank == 175 or rank == 150) then
            LocalPlayer:Kick("\n[Facility Hub]\nReason: Moderator Detected (" .. targetPlayer.Name .. ")")
        end
    end
end

-- Auto Questline (BETA)
task.spawn(function()
    while true do
        task.wait(0.5)
        if not getgenv().AutoQuestline then continue end
        
        local selectedId = getgenv().SelectedQuestline
        if not selectedId then continue end
        
        local questData = QuestsModule.Questlines[selectedId]
        if not questData then continue end
        
        -- Active les settings de quest auto-repeat
        EnsureQuestSettings()
        
        local ui = GetCurrentQuestUI()
        if not ui then continue end
        
        local actualNPCName = questData.npcName or selectedId
        
        -- Verifie si on est sur le bon stage
        local isMatchingStage = false
        for _, stage in ipairs(questData.stages or {}) do
            if stage.title == ui.Title then 
                isMatchingStage = true 
                break 
            end
        end
        
        -- Si pas le bon quest, switch ou accept
        if not ui.IsVisible or not isMatchingStage then
            if ui.SwitchVisible and not isMatchingStage then
                ClickGUI(ui.SwitchBtn)
                task.wait(1)
            else
                pcall(function() QuestRemote:FireServer(actualNPCName) end)
                task.wait(1.5)
            end
            continue
        end
        
        -- On est sur le bon stage, identifier la tache
        local currentStage = nil
        for _, stage in ipairs(questData.stages) do
            if stage.title == ui.Title then 
                currentStage = stage 
                break 
            end
        end
        
        if not currentStage then continue end
        
        local taskType = currentStage.trackingType
        if not taskType then 
            task.wait(1)
            continue 
        end
        
        -- ============================================
        -- DISPATCHER : selon le type de tache, active le bon farm
        -- ============================================
        
        -- 1. Combat / Punches / Ground Smash → equip Combat fist + farm Thief
        if taskType == "CombatNPCKills" or taskType == "CombatPunches" or taskType == "GroundSmashUses" then
            local char = getCharacter()
            local hasCombat = (LocalPlayer.Backpack and LocalPlayer.Backpack:FindFirstChild("Combat")) 
                or (char and char:FindFirstChild("Combat"))
            
            if not hasCombat then
                pcall(function() EquipWeaponRemote:FireServer("Equip", "Combat") end)
                task.wait(1)
            end
            
            getgenv().SelectedMobs = {["Thief"] = true}
            getgenv().FarmSelectedMob = true
            task.spawn(loopFarmSelectedMob)
            
            if taskType == "GroundSmashUses" then
                pcall(function() AbilityRemote:FireServer(1) end)
            end
        
        -- 2. AnyNPCKills → enable Farm Level
        elseif taskType == "AnyNPCKills" then
            getgenv().FarmLevel = true
            task.spawn(loopFarmLevel)
        
        -- 3. HakiNPCKills → enable Arm Haki + Farm Level
        elseif taskType == "HakiNPCKills" then
            getgenv().AutoArmHaki = true
            getgenv().FarmLevel = true
            task.spawn(loopFarmLevel)
        
        -- 4. <Mob>Kills (specific mob) → enable Farm Selected Mob
        elseif taskType:find("Kills") and not taskType:find("Boss") and taskType ~= "PlayerKills" then
            local mobName = taskType:gsub("Kills", "")
            if mobConfig[mobName] then
                getgenv().SelectedMobs = {[mobName] = true}
                getgenv().FarmSelectedMob = true
                task.spawn(loopFarmSelectedMob)
            end
        
        -- 5. DamageTaken → TP au mob et reste sur place
        elseif taskType == "DamageTaken" then
            local targetName = getgenv().SelectedQuestlineMob
            if targetName then
                local target = nil
                local npcFolder = workspace:FindFirstChild("NPCs")
                if npcFolder then
                    for _, v in pairs(npcFolder:GetChildren()) do
                        if v.Name:find(targetName) then
                            local hum = v:FindFirstChildOfClass("Humanoid")
                            if hum and hum.Health > 0 then
                                target = v
                                break
                            end
                        end
                    end
                end
                
                if target then
                    local char = getCharacter()
                    local root = char and char:FindFirstChild("HumanoidRootPart")
                    if root then
                        root.CFrame = target:GetPivot() * CFrame.new(0, 0, 3)
                        root.AssemblyLinearVelocity = Vector3.zero
                    end
                else
                    -- Pas trouve dans NPCs, TP a l'ile
                    local island = MobToIsland[targetName]
                    if island then
                        pcall(function() TPPortalRemote:FireServer(island) end)
                    end
                end
            end
        
        -- 6. PlayerKills → trouve le player et tape
        elseif taskType == "PlayerKills" then
            local targetName = getgenv().SelectedQuestlinePlayer
            local targetPlr = targetName and Players:FindFirstChild(targetName)
            if targetPlr and targetPlr.Character and targetPlr.Character:FindFirstChild("HumanoidRootPart") then
                local tHum = targetPlr.Character:FindFirstChildOfClass("Humanoid")
                if tHum and tHum.Health > 0 then
                    local char = getCharacter()
                    local root = char and char:FindFirstChild("HumanoidRootPart")
                    if root then
                        root.CFrame = targetPlr.Character.HumanoidRootPart.CFrame * CFrame.new(0, 0, 3)
                        equipWeapon()
                        pcall(function() CombatRemote:FireServer() end)
                        pcall(function() AbilityRemote:FireServer(math.random(1, 4)) end)
                    end
                end
            end
        
        -- 7. AnyBossKills → enable Farm All Bosses
        elseif taskType == "AnyBossKills" then
            getgenv().FarmAllBosses = true
            task.spawn(loopFarmAllBosses)
        
        -- 8. <Boss>BossKills → enable boss specifique
        elseif taskType:find("BossKills") then
            local bossName = taskType:gsub("BossKills", "")
            for _, diff in ipairs({"Normal", "Medium", "Hard", "Extreme"}) do
                if bossName:find(diff) then
                    bossName = bossName:gsub(diff, "")
                    break
                end
            end
            
            -- Mappings speciaux
            local lower = bossName:lower()
            if lower:find("strongest") then
                if lower:find("history") then bossName = "Strongest in History"
                elseif lower:find("today") then bossName = "Strongest of Today" end
            end
            
            -- Si c'est un mini boss
            if mobConfig[bossName] then
                getgenv().SelectedMobs = {[bossName] = true}
                getgenv().FarmSelectedMob = true
                task.spawn(loopFarmSelectedMob)
            -- Si dans summon list
            elseif table.find(summonList, bossName) or table.find(otherSummonList, bossName) then
                getgenv().SelectedSummon = bossName
                getgenv().AutoSummon = true
                getgenv().FarmSummonBoss = true
                task.spawn(loopFarmSummonBoss)
            -- Sinon dans world bosses
            elseif table.find(allBossList, bossName) then
                getgenv().SelectedWorldBosses = {[bossName] = true}
                getgenv().FarmSelectedBoss = true
                task.spawn(loopFarmSelectedBoss)
            end
        
        -- 9. Puzzle / Found → lance le solver
        elseif taskType:find("Piece") or taskType:find("Found") then
            local pType = "Dungeon"
            if taskType:find("Slime") then pType = "Slime"
            elseif taskType:find("Demonite") then pType = "Demonite"
            elseif taskType:find("Hogyoku") then pType = "Hogyoku" end
            UniversalPuzzleSolver(pType)
        
        -- 10. Has<Race>Race → utilise Race Reroll
        elseif taskType:find("Has") and taskType:find("Race") then
            local race = taskType:gsub("Has", ""):gsub("Race", "")
            if LocalPlayer:GetAttribute("CurrentRace") ~= race then
                pcall(function() UseItemRemote:FireServer("Use", "Race Reroll", 1) end)
                task.wait(getgenv().RollCD)
            end
        
        -- 11. MonarchClanCheck → utilise Clan Reroll
        elseif taskType == "MonarchClanCheck" then
            if LocalPlayer:GetAttribute("CurrentClan") ~= "Monarch" then
                pcall(function() UseItemRemote:FireServer("Use", "Clan Reroll", 1) end)
                task.wait(getgenv().RollCD)
            end
        
        -- 12. DeemedWorthy → utilise Worthiness Fragment
        elseif taskType == "DeemedWorthy" then
            pcall(function() UseItemRemote:FireServer("Use", "Worthiness Fragment", 1) end)
            task.wait(1)
        
        end
        
        task.wait(1)
    end
end)

-- Webhook Loop (envoi automatique toutes les X minutes)
task.spawn(function()
    while true do
        task.wait(60) -- check chaque minute
        if not getgenv().WebhookEnabled then continue end
        
        local delay = math.max(getgenv().WebhookDelay or 5, 1)
        if not getgenv().LastWebhookSend then
            getgenv().LastWebhookSend = tick()
        end
        
        if tick() - getgenv().LastWebhookSend >= delay * 60 then
            SendWebhook()
            getgenv().LastWebhookSend = tick()
        end
    end
end)

