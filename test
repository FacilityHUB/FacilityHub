            if not processed[item.name] then
                processed[item.name] = true
                table.insert(accessoryList, item.name)
            end
        end
        table.sort(accessoryList)
        pcall(function()
            enchantDropdown:ClearOptions()
            enchantDropdown:InsertOptions(accessoryList)
        end)
    elseif category == "Sword" or category == "Melee" then
        local processed = {}
        for _, item in ipairs(data) do
            if not processed[item.name] then
                processed[item.name] = true
                if not table.find(blessingWeaponList, item.name) then
                    table.insert(blessingWeaponList, item.name)
                end
            end
        end
        table.sort(blessingWeaponList)
        pcall(function()
            blessingDropdown:ClearOptions()
            blessingDropdown:InsertOptions(blessingWeaponList)
        end)
    end
end)

