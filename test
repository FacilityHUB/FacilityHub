local BossRemoteRegistry = {
    ["Strongest of Today"]   = { remoteName = "RequestSpawnStrongestBoss", args = {"StrongestToday"} },
    ["Strongest in History"] = { remoteName = "RequestSpawnStrongestBoss", args = {"StrongestHistory"} },
}

local cachedBossRemotes = {}

local function findRemoteDynamic(name)
    local locations = {
        ReplicatedStorage:FindFirstChild("Remotes"),
        ReplicatedStorage:FindFirstChild("RemoteEvents"),
    }
    for _, folder in pairs(locations) do
        if folder then
            local obj = folder:FindFirstChild(name)
            if obj then return obj end
        end
    end
    return nil
end

local function fireBossRemote(displayName, diff)
    diff = diff or "Normal"
    local internalId = BossMap[displayName] or displayName

    local reg = BossRemoteRegistry[displayName] or BossRemoteRegistry[internalId]
    if reg then
        if not cachedBossRemotes[reg.remoteName] then
            cachedBossRemotes[reg.remoteName] = findRemoteDynamic(reg.remoteName)
        end
        local remote = cachedBossRemotes[reg.remoteName]
        if remote then
            local args = table.clone(reg.args)
            table.insert(args, diff)
            pcall(function() remote:FireServer(table.unpack(args)) end)
            return
        end
    end

    local shortId = internalId:gsub("Boss$", "")
    local candidates = {
        "RequestSpawn" .. internalId,
        "RequestSpawn" .. shortId .. "Boss",
        "RequestSpawn" .. shortId,
    }

    if not cachedBossRemotes[internalId] then
        for _, name in ipairs(candidates) do
            local r = findRemoteDynamic(name)
            if r then cachedBossRemotes[internalId] = r break end
        end
    end

    local foundRemote = cachedBossRemotes[internalId]
    if foundRemote then
        pcall(function() foundRemote:FireServer(diff) end)
        return
    end

    local SummonRemote = findRemoteDynamic("RequestSummonBoss")
    if SummonRemote then
        local summonId = SummonMap[displayName] or internalId
        pcall(function() SummonRemote:FireServer(summonId, diff) end)
    end
end

