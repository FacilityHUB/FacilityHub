    ["Invisible"] = "Power",
    ["Bomb"]      = "Power",
    ["Quake"]     = "Power",
}

local function CleanName(str)
    return str:gsub("%s+", ""):lower()
end

local function GetRealToolName(tool)
    if not tool or not tool:IsA("Tool") then return "" end
    return tool:GetAttribute("_ToolName") or tool.Name
end

local function GetToolType(toolName)
    local cleaned = CleanName(toolName)
    for manualName, toolType in pairs(ManualWeaponClass) do
        if CleanName(manualName) == cleaned then return toolType end
    end
    if WeaponClassModule and WeaponClassModule.Tools then
        for moduleName, toolType in pairs(WeaponClassModule.Tools) do
            if CleanName(moduleName) == cleaned then return toolType end
        end
    end
    if toolName:lower():find("fruit") then return "Power" end
    return "Melee"
end

