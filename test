--    FARM SINGLE MOB
-- ==========================================
local function farmSingleMob(mobName, activeFlagFunc)
    local config = mobConfig[mobName]
    if not config then return end

    if getgenv().IslandTP and getgenv().CurrentIsland ~= config.portal then
        pcall(function() TPPortalRemote:FireServer(config.portal) end)
        getgenv().CurrentIsland = config.portal
        task.wait(getgenv().IslandTPCD)
    end

    local mob = nil
    local searchAttempts = 0
    while activeFlagFunc() and not mob and searchAttempts < 5 do
        mob = findMob(config.npcType, config.isBoss)
        if not mob then
            searchAttempts = searchAttempts + 1
            task.wait(1)
        end
    end
    if not mob then return end

    local mobRoot = mob:FindFirstChild("HumanoidRootPart")
    if mobRoot then moveToTarget(mobRoot) task.wait(0.5) end

    if getgenv().AutoQuest or getgenv().FarmLevel then
        pcall(function() QuestAbandonRemote:FireServer("repeatable") end)
        task.wait(0.3)
        pcall(function() QuestRemote:FireServer(config.questNPC) end)
        task.wait(0.5)
    end

    local killed = 0
    while activeFlagFunc() and killed < config.amount do
        mob = findMob(config.npcType, config.isBoss)
        if not mob then
            getgenv().CurrentTarget = nil
            task.wait(1)
            if not findMob(config.npcType, config.isBoss) then break end
            continue
        end

        local distance   = getgenv().FarmDistance
        local hitboxSize = math.max(40, distance * 2.5)
        pcall(function()
            local hrp = mob.HumanoidRootPart
            if not getgenv().ModifiedMobs[mob] then
                getgenv().ModifiedMobs[mob] = { Size=hrp.Size, Anchored=hrp.Anchored, CanCollide=hrp.CanCollide }
            end
            hrp.Anchored   = true
            hrp.Size       = Vector3.new(hitboxSize, hitboxSize, hitboxSize)
            hrp.CanCollide = false
        end)

        getgenv().CurrentTarget = mob
        local humanoid = mob:FindFirstChild("Humanoid")
        while activeFlagFunc() and humanoid and humanoid.Health > 0 do
            task.wait(0.1)
        end
        if humanoid and humanoid.Health <= 0 then
            killed = killed + 1
        end

        getgenv().CurrentTarget = nil
        task.wait(getgenv().TargetTPCD)
    end
end

local function farmBoss(displayName, activeFlagFunc)
    local internalId = BossMap[displayName] or displayName
    local island     = BossTIMap[displayName]

    if island and getgenv().IslandTP and getgenv().CurrentIsland ~= island then
        pcall(function() TPPortalRemote:FireServer(island) end)
