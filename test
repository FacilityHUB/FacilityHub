local function computeFarmCFrame(mobPart)
    local mobCFrame = mobPart.CFrame
    local mobPos    = mobPart.Position
    local distance  = getgenv().FarmDistance
    local farmType  = getgenv().FarmType
    local finalPos
    if farmType == "Above" then
        finalPos = mobPos + Vector3.new(0, distance, 0)
    elseif farmType == "Below" then
        finalPos = mobPos + Vector3.new(0, -distance, 0)
    else
        finalPos = (mobCFrame * CFrame.new(0, 0, distance)).Position
    end
    return CFrame.lookAt(finalPos, mobPos), finalPos
end

local activeTween = nil
local function moveToTarget(mobPart)
    local char = getCharacter()
    local root = char and char:FindFirstChild("HumanoidRootPart")
    if not root then return end
    local destCF, destPos = computeFarmCFrame(mobPart)
    if getgenv().MovementType == "Tween" then
        local dist = (root.Position - destPos).Magnitude
        if dist > 2 then
            local speed = getgenv().TweenSpeed
            if activeTween then activeTween:Cancel() end
            activeTween = TweenService:Create(root, TweenInfo.new(dist/speed, Enum.EasingStyle.Linear), {CFrame = destCF})
            activeTween:Play()
        else
            if activeTween then activeTween:Cancel() activeTween = nil end
            root.CFrame = destCF
        end
    else
        if activeTween then activeTween:Cancel() activeTween = nil end
        root.CFrame = destCF
    end
    root.Velocity = Vector3.new(0,0,0)
end

