local function updateWeaponRotation()
    local weapons = getAvailableWeapons()
    if #weapons == 0 then getgenv().ActiveWeapon = "" return end
    if tick() - getgenv().LastWeaponSwitch >= getgenv().WeaponSwitchCD then
        getgenv().WeaponRotationIdx = getgenv().WeaponRotationIdx + 1
        if getgenv().WeaponRotationIdx > #weapons then getgenv().WeaponRotationIdx = 1 end
        getgenv().ActiveWeapon = weapons[getgenv().WeaponRotationIdx]
        getgenv().LastWeaponSwitch = tick()
    end
    local exists = false
    for _, n in ipairs(weapons) do
        if n == getgenv().ActiveWeapon then exists = true break end
    end
    if not exists then
        getgenv().ActiveWeapon = weapons[1]
        getgenv().WeaponRotationIdx = 1
    end
end

