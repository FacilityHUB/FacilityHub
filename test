-- Categorize les items pour l'affichage Discord
local function GetFormattedItems(itemSource, isNewItems)
    local categories = {
        Chests = {}, Rerolls = {}, Keys = {},
        Materials = {}, Gears = {}, Runes = {}, Others = {}
    }
    
    for key, data in pairs(itemSource) do
        local name = tostring(type(data) == "table" and data.name or key)
        local qty = tonumber(type(data) == "table" and data.quantity or data) or 1
        
        if not IsRarityAllowed(name) then continue end
        
        local entryText
        if isNewItems then
            local totalInInv = 0
            for _, item in pairs(getgenv().FullInventory or {}) do
                if item.name == name then totalInInv = item.quantity break end
            end
            entryText = string.format("+ [%d] %s [Total: %s]", qty, name, CommaFormat(totalInInv))
        else
            entryText = string.format("- %s: %s", name, CommaFormat(qty))
        end
        
        if name:find("Chest") or name:find("Crate") then
            table.insert(categories.Chests, entryText)
        elseif name:find("Reroll") then
            table.insert(categories.Rerolls, entryText)
        elseif name:find("Key") then
            table.insert(categories.Keys, entryText)
        elseif name:find("Helmet") or name:find("Gloves") or name:find("Body") or name:find("Boots") then
            table.insert(categories.Gears, entryText)
        elseif name:find("Rune") then
            table.insert(categories.Runes, entryText)
        elseif name == "Wood" or name == "Iron" or name == "Obsidian" or name == "Mythril" or name == "Adamantite" then
            table.insert(categories.Materials, entryText)
        else
            table.insert(categories.Others, entryText)
        end
    end
    
    local result = ""
    local order = {"Chests", "Rerolls", "Keys", "Materials", "Gears", "Runes", "Others"}
    for _, cat in ipairs(order) do
        local items = categories[cat]
        if #items > 0 then
            table.sort(items)
            result = result .. "**< " .. cat .. " >**\n```\n"
            for _, line in ipairs(items) do
                result = result .. line .. "\n"
            end
            result = result .. "```\n"
        end
    end
    return result
end

